generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id          String   @id @default(uuid())
  school_name String
  email       String   @unique
  phone       String?
  address     String?
  logo        String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  admins    Admin[]
  students  Student[]
  teachers  Teacher[]
  classes   Class[]
  fee_plans FeePlan[]
  fees      Fee[]

  @@map("schools")
}

model Admin {
  id         String   @id @default(uuid())
  school_id  String
  school     School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  name       String
  email      String   @unique
  password   String
  role       String   @default("super_admin")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([school_id])
  @@map("admins")
}

model Class {
  id         String   @id @default(uuid())
  school_id  String
  school     School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  name       String
  section    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  students Student[]
  teachers Teacher[]
  fees     Fee[]

  @@unique([school_id, name, section])
  @@map("classes")
}

model Student {
  id              String    @id @default(uuid())
  school_id       String
  class_id        String
  school          School    @relation(fields: [school_id], references: [id], onDelete: Cascade)
  class           Class     @relation(fields: [class_id], references: [id], onDelete: Cascade)
  first_name      String
  last_name       String
  email           String?
  phone           String?
  parent_name     String?
  parent_phone    String?
  address         String?
  gender          String?
  dob             DateTime?
  photo           String?
  enrollment_date DateTime  @default(now())
  status          String    @default("active")
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  student_attendance StudentAttendance[]
  fees               Fee[]

  @@index([school_id])
  @@index([class_id])
  @@map("students")
}

model Teacher {
  id            String    @id @default(uuid())
  school_id     String
  class_id      String?
  school        School    @relation(fields: [school_id], references: [id], onDelete: Cascade)
  class         Class?    @relation(fields: [class_id], references: [id], onDelete: SetNull)
  first_name    String
  last_name     String
  email         String?
  phone         String?
  subject       String?
  qualification String?
  address       String?
  gender        String?
  dob           DateTime?
  photo         String?
  joining_date  DateTime  @default(now())
  status        String    @default("active")
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  teacher_attendance TeacherAttendance[]

  @@index([school_id])
  @@map("teachers")
}

model Attendance {
  id         String   @id @default(uuid())
  school_id  String
  date       DateTime
  type       String   @default("student")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  student_attendance StudentAttendance[]
  teacher_attendance TeacherAttendance[]

  @@unique([school_id, date, type])
  @@map("attendance")
}

model StudentAttendance {
  id            String   @id @default(uuid())
  attendance_id String
  student_id    String
  status        String   @default("present")
  remark        String?
  created_at    DateTime @default(now())

  attendance Attendance @relation(fields: [attendance_id], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([attendance_id, student_id])
  @@map("student_attendance")
}

model TeacherAttendance {
  id            String   @id @default(uuid())
  attendance_id String
  teacher_id    String
  status        String   @default("present")
  remark        String?
  created_at    DateTime @default(now())

  attendance Attendance @relation(fields: [attendance_id], references: [id], onDelete: Cascade)
  teacher    Teacher    @relation(fields: [teacher_id], references: [id], onDelete: Cascade)

  @@unique([attendance_id, teacher_id])
  @@map("teacher_attendance")
}

model FeePlan {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  name        String
  amount      Float
  frequency   String   @default("monthly")
  description String?
  due_date    Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  fees Fee[]

  @@index([school_id])
  @@map("fee_plans")
}

model Fee {
  id             String    @id @default(uuid())
  school_id      String
  student_id     String
  class_id       String
  plan_id        String?
  school         School    @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student        Student   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  class          Class     @relation(fields: [class_id], references: [id], onDelete: Cascade)
  plan           FeePlan?  @relation(fields: [plan_id], references: [id], onDelete: SetNull)
  amount         Float
  paid           Float     @default(0)
  due_date       DateTime
  status         String    @default("pending")
  payment_date   DateTime?
  payment_method String?
  remark         String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@index([school_id])
  @@index([student_id])
  @@index([status])
  @@map("fees")
}
